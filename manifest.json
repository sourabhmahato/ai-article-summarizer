{
    "manifest_version": 3,
    "name": "TL;DReader",
    "version": "1.1",
    "description": "Too long? Didn't read? Now you don't have to. AI-powered article summaries in one click.",
    "permissions": ["scripting", "activeTab", "storage"],
    "icons": {
        "16": "icon-16.png",
        "32": "icon-32.png",
        "48": "icon-48.png",
        "128": "icon-128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icon-16.png",
            "32": "icon-32.png",
            "48": "icon-48.png",
            "128": "icon-128.png"
        }
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"]
        }
    ],
    "background": {
        "service_worker": "background.js"
    },
    "options_page": "options.html",
    "host_permissions": ["<all_urls>", "https://api.groq.com/*"]
}